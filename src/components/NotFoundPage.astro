---
interface Props {
  title?: string
  message?: string
  homeLabel?: string
}

const {
  title = 'Página não encontrada',
  message = 'Verifique o endereço ou volte para a página inicial.',
  homeLabel = 'Voltar para a página inicial',
} = Astro.props
---

<main class="not-found-page">
  <div class="container--narrow not-found-page__inner">
    <div class="not-found-page__card">
      <p class="not-found-page__eyebrow">Erro 404</p>
      <h1>{title}</h1>
      <p class="not-found-page__message">{message}</p>

      <div class="not-found-page__actions">
        <a class="not-found-page__button not-found-page__button--primary" href="/">
          {homeLabel}
        </a>
        <a class="not-found-page__button not-found-page__button--secondary" href="/pos-graduacao">
          Ver pós-graduação
        </a>
      </div>
    </div>
  </div>
</main>

<style>
  .not-found-page {
    min-height: 70vh;
    display: grid;
    place-items: center;
    padding: 48px 20px 72px;
    background:
      radial-gradient(circle at top left, rgba(30, 94, 200, 0.14), transparent 34%),
      linear-gradient(180deg, #f7faff 0%, #eef4ff 100%);
  }

  .not-found-page__inner {
    width: 100%;
  }

  .not-found-page__card {
    background: #ffffff;
    border: 1px solid rgba(30, 94, 200, 0.12);
    border-radius: 28px;
    box-shadow: 0 24px 70px rgba(15, 34, 74, 0.08);
    padding: 40px 32px;
    text-align: center;
  }

  .not-found-page__eyebrow {
    margin: 0 0 10px;
    color: #1e5ec8;
    font-size: 14px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .not-found-page h1 {
    margin: 0;
    color: #0f1b33;
    font-size: clamp(32px, 4vw, 46px);
    line-height: 1.05;
  }

  .not-found-page__message {
    max-width: 560px;
    margin: 16px auto 0;
    color: #425066;
    font-size: 17px;
    line-height: 1.6;
  }

  .not-found-page__actions {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 28px;
  }

  .not-found-page__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 50px;
    padding: 0 22px;
    border-radius: 999px;
    font-weight: 800;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
  }

  .not-found-page__button:hover {
    transform: translateY(-1px);
  }

  .not-found-page__button--primary {
    background: linear-gradient(90deg, #0f3f9a 0%, #1e5ec8 100%);
    color: #ffffff;
    box-shadow: 0 14px 30px rgba(30, 94, 200, 0.24);
  }

  .not-found-page__button--secondary {
    border: 1px solid rgba(30, 94, 200, 0.2);
    background: #f5f8ff;
    color: #0f3f9a;
  }

  @media (max-width: 640px) {
    .not-found-page {
      padding: 28px 16px 56px;
    }

    .not-found-page__card {
      border-radius: 22px;
      padding: 32px 20px;
    }

    .not-found-page__actions {
      flex-direction: column;
    }

    .not-found-page__button {
      width: 100%;
    }
  }
</style>
