---
import '../index.css'

import { siteConfig } from '@/site/config'

type StructuredData = Record<string, unknown> | Array<Record<string, unknown>>

interface Props {
  title: string
  description: string
  canonicalPath?: string
  image?: string
  ogType?: 'website' | 'article'
  noindex?: boolean
  structuredData?: StructuredData
  siteTheme?: boolean
}

const {
  title,
  description,
  canonicalPath = Astro.url.pathname,
  image = '/android-chrome-512x512.png',
  ogType = 'website',
  noindex = false,
  structuredData,
  siteTheme = true,
} = Astro.props

const siteUrl = Astro.site ?? new URL(siteConfig.siteUrl)
const canonicalUrl = new URL(canonicalPath, siteUrl).toString()
const socialImage = new URL(image, siteUrl).toString()
const clarityProjectId = import.meta.env.VITE_CLARITY_PROJECT_ID?.trim()
const sitewideNoindex = ['1', 'true', 'yes', 'on'].includes(
  String(import.meta.env.SITE_NOINDEX ?? '')
    .trim()
    .toLowerCase(),
)
const robotsContent = noindex || sitewideNoindex
  ? 'noindex, nofollow'
  : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1'
const serializedStructuredData = structuredData ? JSON.stringify(structuredData, null, 2) : null
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robotsContent} />
    <meta name="author" content={siteConfig.name} />
    <meta name="application-name" content={siteConfig.shortName} />
    <meta name="theme-color" content="#146f63" />
    <meta name="msapplication-TileColor" content="#146f63" />

    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="pt-BR" href={canonicalUrl} />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <meta property="og:locale" content="pt_BR" />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:width" content="512" />
    <meta property="og:image:height" content="512" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />

    {serializedStructuredData ? (
      <script is:inline type="application/ld+json" set:html={serializedStructuredData} />
    ) : null}

    <slot name="head" />

    {clarityProjectId ? (
      <script
        is:inline
        define:vars={{ clarityProjectId }}
      >{`(function(c,l,a,r,i,t,y){c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);})(window, document, "clarity", "script", clarityProjectId);`}</script>
    ) : null}
  </head>
  <body>
    <div class="app-shell">
      <slot />
    </div>
  </body>
</html>
