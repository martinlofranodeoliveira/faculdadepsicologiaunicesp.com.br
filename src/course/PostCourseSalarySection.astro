---
import type { CatalogCourse } from '@/lib/catalogApi'

interface Props {
  course: CatalogCourse
}

const { course } = Astro.props

function formatCurrencyAmount(value: number) {
  return new Intl.NumberFormat('pt-BR', {
    style: 'currency',
    currency: 'BRL',
    minimumFractionDigits: 2,
    maximumFractionDigits: 2,
  }).format(value)
}

function getSalaryBarHeight(value: number, maxValue: number, minHeight: number, maxHeight: number) {
  if (!Number.isFinite(value) || value <= 0 || !Number.isFinite(maxValue) || maxValue <= 0) {
    return minHeight
  }

  const ratio = Math.min(1, value / maxValue)
  return Math.round(minHeight + (maxHeight - minHeight) * ratio)
}

const areaLabel = (course.primaryAreaLabel || course.title).trim() || course.title
const normalizedArea = areaLabel.toLowerCase()
const withoutPos = course.salaryWithoutPos ?? course.salaryAverage ?? 4000
const computedWithPos = course.salaryWithPos ?? course.salarySenior ?? Math.round(withoutPos * 2.625)
const withPos = computedWithPos > withoutPos ? computedWithPos : Math.round(withoutPos * 2.625)
const maxValue = Math.max(withoutPos, withPos)
const items = [
  {
    slug: 'without-pos',
    label: 'Sem Pós-graduação',
    value: formatCurrencyAmount(withoutPos),
    note: 'Profissional graduado',
    height: getSalaryBarHeight(withoutPos, maxValue, 97, 180),
  },
  {
    slug: 'with-pos',
    label: 'Com Pós-graduação',
    value: `+ ${formatCurrencyAmount(withPos)}`,
    note: 'Profissional especialista',
    height: getSalaryBarHeight(withPos, maxValue, 97, 180),
  },
]

const description = `A pós-graduação é o principal divisor de águas para a ascensão na área de ${normalizedArea}, habilitando o profissional para atuar em setores de alta complexidade e cargos de gestão.`
---

<section class="w-full" aria-labelledby="course-salary-title">
  <article class="overflow-hidden rounded-[20px] lg:rounded-[25px] bg-[linear-gradient(115deg,#091149_9.02%,#091149_25.74%,#09419f_98.19%)] px-[18px] py-[18px] lg:px-[45px] lg:py-[45px] shadow-[0_18px_36px_rgba(10,8,8,0.05)]">
    <div class="flex flex-col gap-[18px] lg:grid lg:grid-cols-[minmax(0,526px)_1px_minmax(0,1fr)] lg:items-center lg:gap-[36px]">
      <div class="flex flex-col gap-[14px] lg:gap-[20px]">
        <h2 id="course-salary-title" class="m-0 grid text-[25px] font-extrabold uppercase leading-[30px] tracking-[-0.04em] text-[#8bb6ff] lg:text-[40px] lg:leading-[45px] font-['Kumbh_Sans']">
          <span class="text-white">ESPECIALISTAS GANHAM</span>
          <span>SALÁRIOS 3X MAIORES</span>
        </h2>

        <p class="m-0 max-w-[526px] text-[12px] leading-[1.22] text-white/75 lg:text-[18px] lg:leading-[1.3] font-['Liberation_Sans']">
          {description}
        </p>
      </div>

      <div class="h-px w-full bg-white/14 lg:h-[154px] lg:w-px"></div>

      <div class="hidden lg:flex lg:items-end lg:justify-center lg:gap-[61px]" aria-label={`Faixas salariais estimadas na área de ${areaLabel}`}>
        {items.map((item) => (
          <article class="grid min-w-[210px] justify-items-center gap-[10px] text-center">
            <span class="text-[14px] leading-[1.1] text-white font-['Kumbh_Sans']">
              {item.label}
            </span>
            <strong class="text-[18px] font-bold leading-[1.1] text-[#cee1ff] font-['Kumbh_Sans']">
              {item.value}
            </strong>
            <div
              class="w-[210px] rounded-[13.686px] bg-[linear-gradient(90deg,#09419f_5.5%,#0e59d7_105.68%)]"
              style={`height:${item.height}px;`}
              aria-hidden="true"
            ></div>
            <span class="max-w-[210px] text-[14px] font-light leading-[18px] text-white font-['Kumbh_Sans']">
              {item.note}
            </span>
          </article>
        ))}
      </div>

      <div class="flex flex-col gap-[15px] lg:hidden" aria-label={`Faixas salariais estimadas na área de ${areaLabel}`}>
        {items.map((item, index) => (
          <article
            class="rounded-[14px] bg-[linear-gradient(90deg,#09419f_5.5%,#0e59d7_105.68%)] px-[26px] py-[16px]"
            style={index === 0 ? 'width:62%;max-width:192px;' : 'width:86%;max-width:288px;'}
          >
            <span class="block text-[12px] font-bold uppercase leading-[1.1] text-white font-['Kumbh_Sans']">
              {item.slug === 'without-pos' ? 'Sem Pós' : 'Com Pós'}
            </span>
            <strong class="mt-[6px] block text-[18px] font-bold leading-[1.1] text-white font-['Kumbh_Sans']">
              {item.value}
            </strong>
            <span class="mt-[4px] block text-[12px] leading-[18px] text-white font-['Kumbh_Sans']">
              {item.note}
            </span>
          </article>
        ))}
      </div>
    </div>
  </article>
</section>
