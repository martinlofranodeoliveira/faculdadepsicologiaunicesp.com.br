---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { siteConfig } from '@/site/config'
import { PostCourseThankYouPage } from '@/thankyou/PostCourseThankYouPage'

const title = `Inscrição finalizada | Pós-graduação | ${siteConfig.name}`
const description = 'Recebemos sua inscrição para a pós-graduação.'
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath="/pos-graduacao/inscricao-finalizada"
  noindex={true}
>
  <PostCourseThankYouPage client:load />
</BaseLayout>
